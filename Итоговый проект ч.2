    "# Рассчитаем относительное изменение (осень/лето - 1)\n",
    "pivot_revenue = ticket_revenue_season.pivot(index='event_type_main', columns='season', values='one_ticket_revenue_rub').reset_index()\n",
    "pivot_revenue['relative_change'] = (pivot_revenue['осень'] / pivot_revenue['лето'] - 1) * 100\n",
    "\n",
    "# Цвета в зависимости от знака изменения\n",
    "colors = pivot_revenue['relative_change'].apply(\n",
