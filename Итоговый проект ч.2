   "source": [
    "# Функция для определения сезона по месяцу\n",
    "def get_season(month):\n",
    "    if month in [12, 1, 2]:\n",
    "        return 'зима'\n",
    "    elif month in [3, 4, 5]:\n",
    "        return 'весна'\n",
    "    elif month in [6, 7, 8]:\n",
    "        return 'лето'\n",
    "    elif month in [9, 10, 11]:\n",
    "        return 'осень'\n",
    "\n",
    "# Создаем столбец season\n",
    "df_full['season'] = df_full['month'].apply(get_season)\n",
    "\n",
    "# Проверка первых строк\n",
    "df_full[['order_id', 'created_dt_msk', 'month', 'season']].head(10)"
   ]
