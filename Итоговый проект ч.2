    "\n",
    "plt.figure(figsize=(10,6))\n",
    "plt.bar(\n",
    "    pivot_revenue['event_type_main'],\n",
    "    pivot_revenue['relative_change'],\n",
    "    color=colors\n",
    ")\n",
    "\n",
    "plt.title('Относительное изменение средней выручки с одного билета (осень vs лето), %')\n",
